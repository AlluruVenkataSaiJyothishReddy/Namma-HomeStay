<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HotelHome"
    android:background="@color/warm_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">
                <ImageView
                    android:id="@+id/image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/hotelimg3" />
                <ImageView
                    android:id="@+id/back"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:src="@drawable/blackback"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <ImageView
                    android:id="@+id/edit"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="20dp"
                    android:src="@drawable/ic_baseline_edit_24"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/hotelName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/montserrat_semibold"
                android:text="Homestay Name"
                android:textColor="@color/primary_dark_earth"
                android:textSize="28sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp">
                <TextView
                    android:id="@+id/city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_baseline_location_on_24"
                    android:drawablePadding="8dp"
                    android:text="Location,"
                    android:textColor="@color/grey"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="State"
                    android:textColor="@color/grey"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:text="Homestay description goes here..."
                android:textColor="@color/black"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/rupee"
                    android:drawablePadding="4dp"
                    android:text="0"
                    android:textColor="@color/primary_dark_earth"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="/day"
                    android:textColor="@color/grey"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- Daily Menu Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/primary_light_earth"
                app:contentPadding="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Menu"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        app:drawableStartCompat="@drawable/ic_baseline_restaurant_24"
                        android:drawablePadding="8dp"/>
                    <TextView
                        android:id="@+id/dailyMenuDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="No menu set."
                        android:textColor="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Local Guide Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:text="Local Guide"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark_earth"/>
            <TextView
                android:id="@+id/localGuideDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="4dp"
                android:text="No local tips provided."
                android:textColor="@color/grey" />

            <!-- Stay Details Summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Homestay Stats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark_earth"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:columnCount="2"
                android:rowCount="3">
                <TextView android:text="Owner:" android:layout_columnWeight="1" android:textColor="@color/grey"/>
                <TextView android:id="@+id/ownerName" android:text="-" android:layout_columnWeight="2" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:text="Mobile:" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:textColor="@color/grey"/>
                <TextView android:id="@+id/mobile" android:text="-" android:layout_columnWeight="2" android:layout_marginTop="8dp" android:textColor="@color/black"/>
                <TextView android:text="Total Rooms:" android:layout_columnWeight="1" android:layout_marginTop="8dp" android:textColor="@color/grey"/>
                <TextView android:id="@+id/room" android:text="-" android:layout_columnWeight="2" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/signout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:text="Sign Out"
                android:padding="15dp"
                app:cornerRadius="30dp"
                android:backgroundTint="@color/primary_dark_earth" />

            <!-- Hidden for data binding compatibility if needed -->
            <TextView android:id="@+id/pincode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/area" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/personperroom" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>